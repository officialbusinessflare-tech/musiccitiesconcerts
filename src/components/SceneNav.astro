---
/**
 * SceneNav — sticky pill-style navigation under the header.
 *
 * Row 1 (Browse:) renders one pill per bucket, plus a Birthdays pill and a
 * Venues pill. After the architectural split (Jun 2026), each bucket pill
 * links to that bucket's dedicated top-level page (/florida, /japan, ...).
 * The inline count keeps showing how many entries are in each bucket.
 *
 * Row 2 (Field Trips:) — places we're actually going. Wacken 2026 and
 * Metal London. No counts.
 *
 * Row 3 (Scene Briefs:) — editorial briefing pages that aren't field trips
 * and don't map to a ClickUp bucket. Japan Scene, Japan Global. No counts.
 *
 * Optional `activeBucketId` lets a page highlight its own pill. Pass either
 * a bucket id (e.g. 'florida-metal-scene'), 'birthdays', 'venues', or a
 * field-trip / brief id ('wacken', 'london', 'japan-scene', 'japan-global').
 */
import type { BucketConfig, ConcertEntry } from '../lib/types';

interface Props {
  buckets: BucketConfig[];
  grouped: Map<string, ConcertEntry[]>;
  birthdaysCount?: number;
  /**
   * If set, the matching pill gets the `is-active` class for visual emphasis.
   * Use either a bucket id (e.g. 'florida-metal-scene'), 'birthdays', 'venues',
   * or a field-trip / brief id ('wacken', 'london', 'japan-scene', 'japan-global').
   */
  activeBucketId?: string;
}

const { buckets, grouped, birthdaysCount, activeBucketId } = Astro.props;

/**
 * Map a bucket id to its top-level slug. Kept in one place so the
 * architectural URL scheme is easy to audit.
 */
const BUCKET_HREFS: Record<string, string> = {
  'florida-metal-scene': '/florida',
  'japanese-metal': '/japan',
  'key-festivals': '/festivals',
  'interesting-elsewhere': '/elsewhere',
  'album-releases': '/releases',
};

/**
 * Field Trips — where we're actually going. Chronological order.
 */
const FIELD_TRIPS: { id: string; name: string; href: string }[] = [
  { id: 'wacken', name: 'Wacken 2026', href: '/wacken' },
  { id: 'london', name: 'Metal London', href: '/london' },
];

/**
 * Scene Briefs — editorial dashboards that live alongside the bucket pages.
 * Wacken was promoted to a Field Trip; only the two Japan briefs remain.
 */
const SCENE_BRIEFS: { id: string; name: string; href: string }[] = [
  { id: 'japan-scene', name: 'Japan Scene', href: '/japan-scene' },
  { id: 'japan-global', name: 'Japan Global', href: '/japan-global' },
];
---

<nav class="scene-nav" aria-label="Browse the scene">
  <div class="container scene-nav__inner">
    <div class="scene-nav__row">
      <span class="scene-nav__label">Browse:</span>
      <ul class="scene-nav__list">
        {buckets.map((bucket) => {
          const count = grouped.get(bucket.id)?.length ?? 0;
          const href = BUCKET_HREFS[bucket.id] ?? `#bucket-${bucket.id}`;
          const isActive = activeBucketId === bucket.id;
          return (
            <li class="scene-nav__item">
              <a class={`scene-nav__link${isActive ? ' is-active' : ''}`} href={href} aria-current={isActive ? 'page' : undefined}>
                <span class="scene-nav__name">{bucket.name}</span>
                {bucket.kanji ? <span class="scene-nav__kanji" lang="ja">{bucket.kanji}</span> : null}
                <span class="scene-nav__count" aria-label={`${count} entries`}>{count}</span>
              </a>
            </li>
          );
        })}
        {birthdaysCount && birthdaysCount > 0 ? (
          <li class="scene-nav__item">
            <a class={`scene-nav__link${activeBucketId === 'birthdays' ? ' is-active' : ''}`} href="/birthdays" aria-current={activeBucketId === 'birthdays' ? 'page' : undefined}>
              <span class="scene-nav__name">Birthdays</span>
              <span class="scene-nav__count">{birthdaysCount}</span>
            </a>
          </li>
        ) : null}
        <li class="scene-nav__item">
          <a class={`scene-nav__link${activeBucketId === 'venues' ? ' is-active' : ''}`} href="/venues" aria-current={activeBucketId === 'venues' ? 'page' : undefined}>
            <span class="scene-nav__name">Venues</span>
          </a>
        </li>
      </ul>
    </div>

    <div class="scene-nav__row scene-nav__row--briefs">
      <span class="scene-nav__label">Field Trips:</span>
      <ul class="scene-nav__list">
        {FIELD_TRIPS.map((trip) => {
          const isActive = activeBucketId === trip.id;
          return (
            <li class="scene-nav__item">
              <a class={`scene-nav__link${isActive ? ' is-active' : ''}`} href={trip.href} aria-current={isActive ? 'page' : undefined}>
                <span class="scene-nav__name">{trip.name}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </div>

    <div class="scene-nav__row scene-nav__row--briefs">
      <span class="scene-nav__label">Scene Briefs:</span>
      <ul class="scene-nav__list">
        {SCENE_BRIEFS.map((brief) => {
          const isActive = activeBucketId === brief.id;
          return (
            <li class="scene-nav__item">
              <a class={`scene-nav__link${isActive ? ' is-active' : ''}`} href={brief.href} aria-current={isActive ? 'page' : undefined}>
                <span class="scene-nav__name">{brief.name}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </div>
</nav>
