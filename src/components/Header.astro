---
/**
 * Site header. Wordmark + brand tagline + curator line.
 *
 * The wordmark image lives at /public/assets/wordmark-white.png — drop the real
 * file there (see /public/assets/.placeholders/README.md) and it'll show up
 * automatically. Until then the alt text carries the brand.
 *
 * Optional `title` prop renders a breadcrumb after the wordmark, like:
 *   The Music Cities  /  Wacken 2026 Dashboard
 * The homepage passes no title and the breadcrumb is hidden. On all other
 * pages, the wordmark stays clickable to "/" and the breadcrumb makes it
 * obvious where you are in the site.
 */
interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<header class="site-header">
  <div class="container site-header__inner">
    <div class="site-header__brand-row">
      <a href="/" aria-label="The Music Cities — home" class="site-header__wordmark-link">
        <img
          class="site-header__wordmark"
          src="/assets/wordmark-white.png"
          alt="The Music Cities"
          width="380"
          height="80"
          loading="eager"
          decoding="async"
        />
      </a>
      {title ? (
        <nav class="site-header__breadcrumb" aria-label="Breadcrumb">
          <span class="site-header__breadcrumb-sep" aria-hidden="true">/</span>
          <span class="site-header__breadcrumb-title">{title}</span>
        </nav>
      ) : null}
    </div>
    <p class="site-header__tagline">Where heavy metal is economic development.</p>
    <p class="site-header__sub">Curated by The Music Cities — concerts, releases, the scene.</p>
  </div>
</header>

