---
/**
 * Site header. Wordmark + brand tagline + curator line.
 *
 * The wordmark image lives at /public/assets/wordmark-white.png — drop the real
 * file there (see /public/assets/.placeholders/README.md) and it'll show up
 * automatically. Until then the alt text carries the brand.
 */
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" aria-label="The Music Cities — home" style="display:inline-block;">
      <img
        class="site-header__wordmark"
        src="/assets/wordmark-white.png"
        alt="The Music Cities"
        width="380"
        height="80"
        loading="eager"
        decoding="async"
      />
    </a>
    <p class="site-header__tagline">Where heavy metal is economic development.</p>
    <p class="site-header__sub">Curated by The Music Cities — concerts, releases, the scene.</p>
  </div>
</header>
