---
import type { ConcertEntry } from '../lib/types';

interface Props {
  entry: ConcertEntry;
}

const { entry } = Astro.props;

// Format date: "JUL 10"
const MONTHS = ['JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN', 'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC'];

function formatDateStamp(iso: string): string {
  // Use UTC parts to avoid timezone drift in static builds.
  const [y, m, d] = iso.split('-').map(Number);
  if (!y || !m || !d) return iso;
  return `${MONTHS[m - 1]} ${d}`;
}

const dateStamp = formatDateStamp(entry.date);
const endStamp = entry.endDate && entry.endDate !== entry.date ? formatDateStamp(entry.endDate) : null;

// Headline: prefer first parsed band, fall back to raw name.
const headline = entry.bands[0] ?? entry.name;

// Meta line: venue + city + state/country (the dedupe step in venue-collision
// rescue means venue and city can sometimes be the same string — collapse them).
const metaParts: string[] = [];
if (entry.venue) metaParts.push(entry.venue);
if (entry.city && entry.city !== entry.venue) metaParts.push(entry.city);
if (entry.state) metaParts.push(entry.state);
else if (entry.country) metaParts.push(entry.country);
const venueLine = metaParts.join(' — ');

const priorityClass =
  entry.priority === 'urgent' || entry.priority === 'high' ? 'card__priority' : 'card__priority card__priority--low';

const showPriority = entry.priority === 'urgent' || entry.priority === 'high';

// Public-facing CTA. Only link if we have a real ticket URL the visitor can
// use — NEVER fall back to the internal ClickUp task URL.
const ctaUrl = entry.ticketUrl;
const ctaLabel = 'Tickets';
---

<article class="card">
  <div class="card__date">
    {dateStamp}{endStamp ? <span>&nbsp;–&nbsp;{endStamp}</span> : null}
  </div>

  <h3 class="card__title">{headline}</h3>

  {venueLine ? <p class="card__meta">{venueLine}</p> : null}

  {entry.description ? <p class="card__desc">{entry.description}</p> : null}

  <div class="card__footer">
    {showPriority ? (
      <span class={priorityClass} aria-label={`Priority: ${entry.priority}`}>
        {entry.priority}
      </span>
    ) : (
      <span aria-hidden="true"></span>
    )}

    {ctaUrl ? (
      <a class="card__ticket" href={ctaUrl} target="_blank" rel="noopener noreferrer">
        {ctaLabel} &rarr;
      </a>
    ) : (
      <span aria-hidden="true"></span>
    )}
  </div>
</article>
