---
/**
 * Site footer. Replace the # placeholders with the real social URLs:
 *   - YouTube channel
 *   - Instagram handle
 *   - Facebook page
 *   - X (Twitter) handle
 *
 * Then commit + redeploy. No code change required.
 */

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <nav class="site-footer__social" aria-label="Social media">
      {/* TODO: Kevin — replace # with actual URLs */}
      <a href="#youtube" rel="noopener" aria-label="YouTube">YouTube</a>
      <a href="#instagram" rel="noopener" aria-label="Instagram">Instagram</a>
      <a href="#facebook" rel="noopener" aria-label="Facebook">Facebook</a>
      <a href="#x" rel="noopener" aria-label="X (formerly Twitter)">X</a>
    </nav>

    <p class="site-footer__tagline">Where heavy metal is economic development.</p>

    <p class="site-footer__meta">
      &copy; {year} The Music Cities. Updated nightly from our editorial calendar.
    </p>
  </div>
</footer>
