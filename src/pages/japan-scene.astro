      '<strong>Full tour chase route:</strong> Fukuoka → Hiroshima → Nagoya → Osaka → Sapporo (fly) → Sendai → Kanazawa → Niigata → Tokyo. 21-day JR Pass (¥100,000) recommended.',
    ],
    bands: ['LOVEBITES x10'],
  },
  {
    label: 'Summer Festival Window',
    title: 'Summer Sonic into LOVEBITES Tour',
    dates: 'August 13 – September 6, 2026 (25 days)',
    details: [
      "<strong>Aug 14-16:</strong> Summer Sonic 2026 (BABYMETAL's SONIC METAL STAGE + festival) — Chiba/Osaka",
      '<strong>Aug 29:</strong> LOVEBITES — Fukuoka',
      '<strong>Aug 30:</strong> LOVEBITES — Hiroshima',
      '<strong>Sep 4:</strong> LOVEBITES — Nagoya',
      '<strong>Sep 6:</strong> LOVEBITES — Osaka',
      '<strong>Route:</strong> Chiba → (sightsee) → Fukuoka → Hiroshima → Nagoya → Osaka',
    ],
    bands: ['BABYMETAL', 'LOVEBITES x4', 'METALVERSE (likely)'],
  },
  {
    label: 'Once-in-a-Lifetime',
    title: 'BAND-MAID Budokan Farewell',
    dates: 'November 1–14, 2026 (14 days)',
    details: [
      '<strong>Nov 1:</strong> BAND-MAID — Nagoya (venue TBA)',
      '<strong>Nov 3:</strong> BAND-MAID @ Namba Hatch — Osaka',
      '<strong>Nov 13:</strong> BAND-MAID @ Nippon Budokan Night 1 — Tokyo',
      '<strong>Nov 14:</strong> BAND-MAID @ Nippon Budokan Night 2 FINAL — Tokyo',
      "This is their last show before hiatus. They won't return until 2028. If BAND-MAID matters to you, this is the trip.",
      '<strong>Route:</strong> Nagoya → Osaka → Tokyo. Autumn foliage season.',
    ],
    bands: ['BAND-MAID x4 (FINAL)'],
  },
  {
    label: 'Add-On',
    title: 'Seoul Side-Trip: Rolling Quartz',
    dates: 'Flexible — add 2-3 days to any trip',
    details: [
      'Rolling Quartz is Korean-based. Seoul is ~2.5 hours from Tokyo by air (budget airlines from ¥15,000 one-way). Monitor their schedule for Korea dates that overlap your Japan window.',
    ],
    bands: ['Rolling Quartz'],
  },
];

type Festival = { title: string; date: string; body: string };
const festivals: Festival[] = [
  { title: 'Summer Sonic 2026 (25th Anniversary)', date: 'August 14–16 · Chiba (Tokyo area) + Osaka', body: '<span class="jms-hl">BABYMETAL curating "SONIC METAL STAGE"</span> at both venues. Three-day mega-festival. BABYMETAL\'s 15th anniversary. METALVERSE likely on the metal stage. Headliners: The Strokes, L\'Arc-en-Ciel, Jamiroquai.' },
  { title: 'UNLUCKY FES 2026', date: "June 6 · Kawasaki CLUB CITTA'", body: '<span class="jms-hl">NEMOPHILA confirmed</span>. Multi-band festival that often features female-fronted acts. One station from Tokyo.' },
  { title: "NAON's BUNTAI 2026", date: 'Date TBD · Produced by SHOW-YA', body: '<span class="jms-hl">NEMOPHILA confirmed</span>. Legendary all-female band showcase. Previous editions featured LOVEBITES, BRIDEAR, and others.' },
  { title: 'Nemophila Ten Fes', date: 'Date TBD · Announced by Nemophila', body: '<span class="jms-hl">All-female bands</span> festival announced by Nemophila. Lineup and date pending; deep dive on next concert sweep.' },
  { title: 'Heavy Kawaii Fes 2026', date: 'July 31 – August 2 · Meijiza, Tokyo', body: '<span class="jms-hl">3-day festival</span>. Day 1 (Jul 31): AKB48 Band x KOIAI. Day 2 (Aug 1): Shiritsu Ebisu Chugaku x KOIAI. Day 3 (Aug 2): METALVERSE x KOIAI.' },
  { title: 'Loud Park 2026', date: 'Historically October · Saitama Super Arena / Makuhari Messe', body: 'Japan\'s premier metal festival. No 2026 edition confirmed yet. If it returns, best single-event chance to see multiple bands on one bill.' },
