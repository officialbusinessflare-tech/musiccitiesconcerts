// --- Past-show filter: only render shows from the last 7 days as past ---
const sevenDaysAgo = new Date();
sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);
const sevenDaysAgoISO = sevenDaysAgo.toISOString().slice(0, 10);
const todayISO = new Date().toISOString().slice(0, 10);

const allEntries: ConcertEntry[] = (concertsData as ConcertsDataFile).entries ?? [];

// Helper: format date as "MMM DD" or "MMM DD-DD"
function fmtDate(iso: string, endIso?: string): string {
  const d = new Date(iso + 'T00:00:00Z');
  const month = d.toLocaleString('en-US', { month: 'short', timeZone: 'UTC' }).toUpperCase();
  const day = d.getUTCDate();
  if (endIso && endIso !== iso) {
    const d2 = new Date(endIso + 'T00:00:00Z');
    return `${month} ${day}-${d2.getUTCDate()}`;
  }
  return `${month} ${day}`;
}

function fmtDateLong(iso: string): string {
  const d = new Date(iso + 'T00:00:00Z');
  return d.toLocaleString('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' });
}

function entryMatchesBand(entry: ConcertEntry, matchNames: string[]): boolean {
  if (entry.isRelease) return false;
  if (!entry.bands || entry.bands.length === 0) return false;
  const norm = (s: string) => s.toLowerCase().replace(/[\s._\-]+/g, '').replace(/✅/g, '').trim();
  const wanted = matchNames.map(norm);
  return entry.bands.some((b) => {
    const nb = norm(b);
    return wanted.some((w) => nb === w || nb.startsWith(w) || w.startsWith(nb));
  });
}

function isVisible(entry: ConcertEntry): boolean {
  // Keep all upcoming + anything within last 7 days
  return entry.date >= sevenDaysAgoISO;
}

// Restrict to physically-in-Japan shows. Conservative: if uncertain, drop.
// Bands touring outside Japan surface on /japan-global instead.
function isInJapan(entry: ConcertEntry): boolean {
  const state = (entry.state || '').toLowerCase().trim();
  const city = (entry.city || '').toLowerCase();
  const venue = (entry.venue || '').toLowerCase();

  // Direct state match
  if (state === 'japan' || state === 'jp') return true;

  // City keyword match (well-known Japanese cities)
  const japaneseCities = [
    'tokyo', 'osaka', 'nagoya', 'kyoto', 'fukuoka', 'sapporo',
    'sendai', 'hiroshima', 'niigata', 'kanazawa', 'yokohama',
    'kobe', 'chiba', 'shibuya', 'shinjuku', 'kawasaki',
    'kumamoto', 'saitama', 'yamanashi', 'kashiwa', 'hokkaido',
    'aichi', 'miyagi', 'ishikawa', 'haneda',
  ];
  if (japaneseCities.some((jc) => city.includes(jc))) return true;

  // Venue keyword match (well-known Japan venue prefixes)
  if (venue.includes('zepp')) return true;
  if (venue.includes('budokan')) return true;
  if (venue.includes('tokyo grit')) return true;
  if (venue.includes('meijiza')) return true;
  if (venue.includes('shibuya')) return true;
  if (venue.includes('namba hatch')) return true;

  // Otherwise — assume NOT Japan (conservative; better to under-show
  // here than to leak US/EU dates onto the in-Japan dashboard).
  return false;
}

type BandShow = { dateLabel: string; iso: string; venue: string; city: string; note?: string; past: boolean };
function bandShows(matchNames: string[]): BandShow[] {
  return allEntries
    .filter((e) => entryMatchesBand(e, matchNames))
    .filter(isVisible)
    .filter(isInJapan)
    .sort((a, b) => a.date.localeCompare(b.date))
    .map((e) => {
      const cityState = e.state ? `${e.city ?? ''} ${e.state}`.trim() : (e.city ?? '');
      return {
        dateLabel: fmtDate(e.date, e.endDate),
        iso: e.date,
        venue: e.venue || '',
        city: cityState,
        note: e.description || undefined,
        past: e.date < todayISO,
      };
    });
}

// Render bands with shows
const bandsWithShows = bands.map((b) => ({ ...b, shows: bandShows(b.matchNames) }));

// --- Timeline: group all visible entries by month ---
const trackedMatchNames = bands.flatMap((b) => b.matchNames);
const timelineEntries = allEntries
  .filter((e) => !e.isRelease)
  .filter(isVisible)
  .filter(isInJapan)
  .filter((e) => bands.some((b) => entryMatchesBand(e, b.matchNames)))
  .sort((a, b) => a.date.localeCompare(b.date));

// Group by year-month
type TLEvent = { dateLabel: string; iso: string; band: string; venue: string; city: string; past: boolean };
type TLMonth = { key: string; name: string; pastMonth: boolean; events: TLEvent[] };
const monthMap = new Map<string, TLMonth>();
for (const e of timelineEntries) {
  const ym = e.date.slice(0, 7);
  const d = new Date(e.date + 'T00:00:00Z');
  const monthName = d.toLocaleString('en-US', { month: 'long', year: 'numeric', timeZone: 'UTC' });
  if (!monthMap.has(ym)) {
    monthMap.set(ym, {
      key: ym,
      name: monthName,
      pastMonth: ym < todayISO.slice(0, 7),
      events: [],
    });
  }
  const cityState = e.state ? `${e.city ?? ''} ${e.state}`.trim() : (e.city ?? '');
  const bandLabel = (e.bands ?? []).join(' / ') || '—';
  monthMap.get(ym)!.events.push({
    dateLabel: fmtDateLong(e.date),
    iso: e.date,
    band: bandLabel,
    venue: e.venue || '',
    city: cityState,
    past: e.date < todayISO,
  });
}
const timeline: TLMonth[] = [...monthMap.values()].sort((a, b) => a.key.localeCompare(b.key));

// --- Static editorial content preserved from brief ---
type Trip = { label: string; title: string; dates: string; details: string[]; bands: string[] };
const trips: Trip[] = [
