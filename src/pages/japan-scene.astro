<BaseLayout
  title="Japan Scene 2026 | The Music Cities"
  description="In-Japan shows from 14 J-metal bands: confirmed dates, recommended trip windows, festivals, and travel intel for the 2026 touring year."
>
  <Header />

  <section class="dash-hero">
    <div class="container">
      <p class="dash-hero__eyebrow">Scene Brief</p>
      <h1 class="dash-hero__title">Japan <em>Scene 2026</em></h1>
      <p class="dash-hero__subtitle">In-Japan dates from the J-metal watch list</p>
      <p class="dash-hero__lede">
        All-female Japanese metal bands (+ BABYMETAL & Rolling Quartz), every confirmed Japan show
        we have, four recommended trip windows, the festival calendar, and the travel intel to
        navigate buying tickets, riding the Shinkansen, and finding the right metal bar.
      </p>
      <div class="jms-stats">
        <div class="jms-stat"><div class="jms-stat__num">{bands.length}</div><div class="jms-stat__lbl">Bands tracked</div></div>
        <div class="jms-stat"><div class="jms-stat__num">{activeCount}</div><div class="jms-stat__lbl">Active in 2026</div></div>
        <div class="jms-stat"><div class="jms-stat__num">50+</div><div class="jms-stat__lbl">Confirmed shows</div></div>
        <div class="jms-stat"><div class="jms-stat__num">10+</div><div class="jms-stat__lbl">Cities</div></div>
      </div>
    </div>
  </section>

  <nav class="dash-tabs" aria-label="Section tabs">
    <button class="dash-tab is-active" data-target="jms-bands" type="button">All Bands</button>
    <button class="dash-tab" data-target="jms-timeline" type="button">Timeline</button>
    <button class="dash-tab" data-target="jms-trips" type="button">Trip Options</button>
    <button class="dash-tab" data-target="jms-festivals" type="button">Festivals</button>
    <button class="dash-tab" data-target="jms-travel" type="button">Travel Intel</button>
  </nav>

  <main class="dash-main">
    <div class="container">

      <section id="jms-bands" class="dash-tabpanel is-active">
        <h2 class="dash-section__title">Band Roster &amp; Confirmed Shows</h2>
        <p class="dash-section__intro">All confirmed 2026 Japan dates. Past shows dimmed.</p>
        <div class="jms-band-grid">
          {bands.map((b) => (
            <article class="jms-band">
              <header class="jms-band__head">
                <div class="jms-band__name">{b.name}</div>
                <span class={`jms-status jms-status--${b.status}`}>{b.statusLabel}</span>
              </header>
              <div class="jms-band__genre">{b.genre}</div>
              {b.members ? <div class="jms-band__members">{b.members}</div> : null}
              {b.shows && b.shows.length > 0 ? (
                <ul class="jms-shows">
                  {b.shows.map((s) => (
                    <li class={s.past ? 'jms-show jms-show--past' : 'jms-show'}>
                      <span class="jms-show__date">{s.date}</span>
                      <div class="jms-show__body">
                        {s.venue ? <span class="jms-show__venue">{s.venue}</span> : null}
                        {s.city ? <Fragment> — <span class="jms-show__city">{s.city}</span></Fragment> : null}
                        {s.note ? <div class="jms-show__note">{s.note}</div> : null}
                      </div>
                    </li>
                  ))}
                </ul>
              ) : null}
              {b.noShowsNote ? <p class="jms-no-shows">{b.noShowsNote}</p> : null}
              {b.footer ? <p class="jms-band__footer">{b.footer}</p> : null}
            </article>
          ))}
        </div>
      </section>

      <section id="jms-timeline" class="dash-tabpanel">
        <h2 class="dash-section__title">2026 Japan Show Timeline</h2>
        <p class="dash-section__intro">All confirmed Japan dates in chronological order.</p>
        <div class="jms-timeline">
          {timeline.map((m) => (
            <div class="jms-tl-month">
              <div class={m.pastMonth ? 'jms-tl-dot jms-tl-dot--past' : 'jms-tl-dot jms-tl-dot--upcoming'}></div>
              <div class={
                m.pastMonth
                  ? 'jms-tl-month-name jms-tl-month-name--past'
                  : m.titleColor === 'accent'
                  ? 'jms-tl-month-name jms-tl-month-name--accent'
                  : m.titleColor === 'purple'
                  ? 'jms-tl-month-name jms-tl-month-name--purple'
                  : 'jms-tl-month-name'
              }>{m.name}</div>
              <div class="jms-tl-events">
                {m.events.map((e) => (
                  <div class={
                    e.past
                      ? 'jms-tl-event jms-tl-event--past'
                      : e.highlight === 'lovebites'
                      ? 'jms-tl-event jms-tl-event--lovebites'
                      : e.highlight === 'bandmaid'
                      ? 'jms-tl-event jms-tl-event--bandmaid'
                      : 'jms-tl-event'
                  }>
                    <span class="jms-tl-date">{e.date}</span>
                    <span class="jms-tl-band">{e.band}</span>
                    <span class="jms-tl-venue">{e.venue}</span>
                    <span class="jms-tl-city">{e.city}</span>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <section id="jms-trips" class="dash-tabpanel">
        <h2 class="dash-section__title">Recommended Trip Windows</h2>
        <p class="dash-section__intro">Optimized multi-band itineraries based on all confirmed dates.</p>
        {trips.map((t) => (
          <div class="jms-trip">
            <div class="jms-trip__label">{t.label}</div>
            <div class="jms-trip__title">{t.title}</div>
            <div class="jms-trip__dates">{t.dates}</div>
            {t.details.map((d) => (
              <p class="jms-trip__detail" set:html={d}></p>
            ))}
            <div class="jms-trip__bands">
              {t.bands.map((b) => <span class="jms-trip__tag">{b}</span>)}
            </div>
          </div>
        ))}
      </section>

      <section id="jms-festivals" class="dash-tabpanel">
        <h2 class="dash-section__title">2026 Festivals</h2>
        <p class="dash-section__intro">Major events featuring bands from the watch list.</p>
        {festivals.map((f) => (
          <div class="jms-festival">
            <h3>{f.title}</h3>
            <div class="jms-festival__date">{f.date}</div>
            <p set:html={f.body}></p>
          </div>
        ))}
      </section>

      <section id="jms-travel" class="dash-tabpanel">
        <h2 class="dash-section__title">Travel Intel</h2>
        <p class="dash-section__intro">Everything you need to navigate Japan as a metalhead.</p>
        <div class="jms-info-grid">
          <div class="jms-info">
            <h3>Buying Tickets</h3>
            <p>Japan's three major platforms all require a Japanese phone number for SMS verification:</p>
            <ul>
              <li><strong>e+ (eplus)</strong> — "e+ International" portal for select events (no JP phone needed), ~5% coverage</li>
              <li><strong>Ticket Pia</strong> — partners with 7-Eleven / FamilyMart for in-store pickup</li>
              <li><strong>Lawson Ticket</strong> — use Loppi machines at any Lawson</li>
            </ul>
            <p><strong>Strategy:</strong> Get a Japanese SIM card at the airport, register accounts, buy during general sale at convenience store machines. BAND-MAID tickets on sale now (Standing ¥7,700 / Reserved ¥8,800).</p>
          </div>
          <div class="jms-info">
            <h3>Japan Rail Pass</h3>
            <ul>
              <li><strong>7-day:</strong> <span class="jms-price">¥50,000</span> (~$345)</li>
              <li><strong>14-day:</strong> <span class="jms-price">¥80,000</span></li>
              <li><strong>21-day:</strong> <span class="jms-price">¥100,000</span></li>
            </ul>
            <p>The 21-day pass is ideal for chasing the full LOVEBITES September tour across 8 cities. A 7-day pass covers the Nagoya→Osaka→Tokyo corridor for shorter trips.</p>
          </div>
          <div class="jms-info">
            <h3>Where to Stay</h3>
            <ul>
              <li><strong>Shibuya (Tokyo)</strong> — #1 pick. Walk to WWW, WWW X, Star Lounge, O-EAST, Club Quattro</li>
              <li><strong>Shinjuku (Tokyo)</strong> — Near ANTIKNOCK, Loft. Major transport hub</li>
              <li><strong>Shinsaibashi/Namba (Osaka)</strong> — Near OSAKA MUSE, Zepp Osaka, Hokage metal bar</li>
            </ul>
            <p>For Zepp Haneda shows: stay near Haneda Airport or Kamata station (10 min walk).</p>
          </div>
          <div class="jms-info">
            <h3>Metal Spots</h3>
            <ul>
              <li><strong>GODZ (Shinjuku)</strong> — Best metal bar in Japan</li>
              <li><strong>Hokage (Osaka)</strong> — Metalhead pub, touring bands hang out here</li>
              <li><strong>Disk Union (Shibuya/Shinjuku)</strong> — Multi-floor record shops, massive metal sections</li>
              <li><strong>Tower Records Shibuya</strong> — 9 floors. The metal floor is a pilgrimage</li>
            </ul>
          </div>
          <div class="jms-info">
            <h3>September Weather</h3>
            <ul>
              <li><strong>Temp:</strong> 23–30°C (73–86°F), hotter early month</li>
              <li><strong>Humidity:</strong> High. Feels like 35°C. Muggy indoor venues</li>
              <li><strong>Typhoons:</strong> 1–2 per month. Can disrupt Shinkansen for half a day</li>
              <li><strong>Pack:</strong> Light clothes, rain jacket, portable fan, waterproof phone case</li>
            </ul>
          </div>
          <div class="jms-info">
            <h3>Key Links to Monitor</h3>
            <ul>
              <li><strong>lovebites.jp/shows</strong> — LOVEBITES schedule</li>
              <li><strong>bandmaid.tokyo</strong> — BAND-MAID official</li>
              <li><strong>babymetal.com</strong> — BABYMETAL tour page</li>
              <li><strong>metalverse-world.com</strong> — METALVERSE</li>
              <li><strong>zilqy.com/tour</strong> — ZILQY</li>
              <li><strong>nemophila.tokyo/en/live</strong> — NEMOPHILA</li>
              <li><strong>hanabietour.com</strong> — HANABIE</li>
              <li><strong>japanconcerttickets.com</strong> — Aggregator (English)</li>
            </ul>
          </div>
        </div>
      </section>

      <p class="dash-footnote" style="margin-top:2rem;">Dates subject to change. Check official band sites for the latest. Stay heavy.</p>
    </div>
  </main>

  <Footer />

  <script is:inline>
    (function () {
      function activate(target) {
        document.querySelectorAll('.dash-tabpanel').forEach(function (p) { p.classList.remove('is-active'); });
        document.querySelectorAll('.dash-tab').forEach(function (t) { t.classList.remove('is-active'); });
        var panel = document.getElementById(target);
        if (panel) panel.classList.add('is-active');
        var btn = document.querySelector('.dash-tab[data-target="' + target + '"]');
        if (btn) btn.classList.add('is-active');
      }
      document.querySelectorAll('.dash-tab').forEach(function (t) {
        t.addEventListener('click', function () { activate(t.getAttribute('data-target')); });
      });
    })();
  </script>
</BaseLayout>
