/**
 * /japan-scene — In-Japan editorial dashboard.
 *
 * Band roster + trip windows + festivals + travel intel are STATIC editorial
 * intel from the source brief. Per-band show lists + timeline view are now
 * DYNAMIC, pulled from concerts.json at build time (same pattern as /japan).
 *
 * Past-show filter: only shows from the last 7 days render (faded). Anything
 * older drops off entirely.
 */

type Status = 'active' | 'hot' | 'hiatus' | 'limited' | 'intl' | 'farewell';

type Band = {
  name: string;
  matchNames: string[]; // case-insensitive name variants used to match concerts.json entries
