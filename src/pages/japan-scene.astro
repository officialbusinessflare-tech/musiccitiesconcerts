/**
 * /japan-scene — In-Japan editorial dashboard.
 *
 * Built from the japan-metal-trip-2026 brief. Tracks 14 J-metal bands'
 * confirmed Japan dates, a chronological timeline, recommended trip windows,
 * festivals, and travel intel. Five tabs, JS-driven.
 *
 * Distinct from /japan (the auto-generated calendar of Japan-bucket entries
 * from ClickUp). This page is editorial planning, /japan is the live feed.
 */

type Status = 'active' | 'hot' | 'hiatus' | 'limited' | 'intl' | 'farewell';

type Show = { date: string; venue?: string; city?: string; note?: string; past?: boolean };

