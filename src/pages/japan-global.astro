---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { ConcertsDataFile, ConcertEntry } from '../lib/types';
import concertsData from '../../concerts.json';

/**
 * /japan-global — J-bands touring abroad.
 *
 * Band roster metadata + festival cards are STATIC editorial intel. Per-band
 * tour cards + per-region tour groups (North America / Europe / Asia-Oceania)
 * are DYNAMIC, pulled from concerts.json at build time.
 *
 * Past-show filter: only shows from the last 7 days render (faded). Anything
 * older drops off entirely.
 */

type Region = 'japan' | 'na' | 'eu' | 'asia' | 'oceania' | 'festival';

type BandDef = {
  id: string;
  name: string;
  matchNames: string[];
  meta: string;
  countKind: string;
  open?: boolean;
  note?: string;
};

const bandDefs: BandDef[] = [
  { id: 'bt-lovebites', name: 'LOVEBITES', matchNames: ['LOVEBITES', 'Lovebites'], meta: 'Power / Speed Metal · "Outstanding Tour Japan 2026" + Wacken', countKind: 'red', open: true },
  { id: 'bt-bandmaid', name: 'BAND-MAID', matchNames: ['BAND-MAID', 'Band-Maid', 'BAND MAID'], meta: 'Hard Rock / Metal · First World Tour · Budokan Finale · Hiatus after Nov', countKind: 'purple', note: 'BAND-MAID enters hiatus after the Nov 14 Budokan show. They return for their 15th anniversary in 2028.' },
  { id: 'bt-babymetal', name: 'BABYMETAL', matchNames: ['BABYMETAL'], meta: 'Kawaii Metal · World Tour 2026 · 15th Anniversary · Curating Summer Sonic Metal Stage', countKind: 'pink' },
  { id: 'bt-hanabie', name: 'HANABIE.', matchNames: ['HANABIE.', 'HANABIE', 'Hanabie'], meta: 'Nu-Metal / Metalcore · North America + Japan tours', countKind: 'cyan' },
  { id: 'bt-metalverse', name: 'METALVERSE', matchNames: ['METALVERSE'], meta: 'Kawaii Metal · BABYMETAL universe · "GARDEN OF EDEN" solo show', countKind: 'gold', note: 'METALVERSE likely to appear at Summer Sonic\'s SONIC METAL STAGE (Aug 14-16) curated by BABYMETAL.' },
  { id: 'bt-nemophila', name: 'NEMOPHILA', matchNames: ['NEMOPHILA', 'Nemophila'], meta: 'Heavy Metal · "MY TURN" NA tour + Japan festivals', countKind: 'green' },
  { id: 'bt-zilqy', name: 'ZILQY', matchNames: ['ZILQY', 'Zilqy'], meta: 'Heavy Metal Supergroup · "Rise to Liberation" Tour · SOLD OUT', countKind: 'gold', note: 'First full-length album expected Fall 2026 — likely to trigger more tour dates.' },
  { id: 'bt-rq', name: 'ROLLING QUARTZ', matchNames: ['ROLLING QUARTZ', 'Rolling Quartz', '✅ Rolling Quartz'], meta: 'Korean Rock/Metal · "MY TURN" NA + EU Tour', countKind: 'cyan', note: 'Korean-based, no Japan or Asia dates confirmed. A Seoul side-trip from Japan is ~2.5 hrs by air.' },
  { id: 'bt-jiluka', name: 'JILUKA', matchNames: ['JILUKA', 'Jiluka'], meta: 'Visual Kei / Metalcore · North America tour', countKind: 'cyan' },
  { id: 'bt-trident', name: 'TRiDENT', matchNames: ['TRiDENT', 'TRIDENT', 'Trident'], meta: 'Hard Rock / Metal · "King of the Sea Tour 2026"', countKind: 'green', note: '"King of the Sea Tour 2026" — schedule details still TBA. Japan only.' },
  { id: 'bt-bridear', name: 'BRIDEAR', matchNames: ['BRIDEAR', 'Bridear'], meta: 'Melodic Metal · EU/UK tour being rescheduled', countKind: 'muted' },
  { id: 'bt-ladybaby', name: 'LADYBABY', matchNames: ['LADYBABY', 'Ladybaby'], meta: 'Idol Metal · Minimal 2026 activity', countKind: 'muted' },
  { id: 'bt-hiatus', name: "ALDIOUS / MARY'S BLOOD", matchNames: ['ALDIOUS', 'Aldious', "MARY'S BLOOD", "Mary's Blood"], meta: 'Both on indefinite hiatus · No 2026 dates', countKind: 'muted', note: 'ALDIOUS: Hiatus since May 2025. Guitarist Toki departed to form ZILQY. MARY\'S BLOOD: Inactive since April 2022.' },
];

// --- Past-show filter ---
const sevenDaysAgo = new Date();
sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);
const sevenDaysAgoISO = sevenDaysAgo.toISOString().slice(0, 10);
const todayISO = new Date().toISOString().slice(0, 10);

const allEntries: ConcertEntry[] = (concertsData as ConcertsDataFile).entries ?? [];

// --- Region classification ---
const NA_STATES = new Set(['AL','AK','AZ','AR','CA','CO','CT','DE','FL','GA','HI','ID','IL','IN','IA','KS','KY','LA','ME','MD','MA','MI','MN','MS','MO','MT','NE','NV','NH','NJ','NM','NY','NC','ND','OH','OK','OR','PA','RI','SC','SD','TN','TX','UT','VT','VA','WA','WV','WI','WY','DC']);
const CA_PROVS = new Set(['ON','QC','BC','AB','MB','SK','NS','NB','NL','PE','YT','NT','NU']);
const MX_STATES = new Set(['MX']);
const EU_KEYWORDS = ['UK', 'United Kingdom', 'England', 'London', 'Germany', 'France', 'Italy', 'Spain', 'Netherlands', 'Belgium', 'Sweden', 'Norway', 'Denmark', 'Finland', 'Poland', 'Ireland', 'Scotland', 'Wacken', 'Berlin', 'Paris', 'Munich', 'Frankfurt', 'Amsterdam', 'Cologne', 'Warsaw', 'Donington', 'Solvesborg', 'Solves', 'Oslo', 'Copenhagen', 'Dessel', 'Leipzig', 'Stockholm', 'Helsinki', 'Vienna', 'Zurich', 'Brussels', 'Lisbon', 'Madrid', 'Barcelona', 'Dublin'];
const ASIA_KEYWORDS = ['Japan', 'Tokyo', 'Osaka', 'Kyoto', 'Nagoya', 'Sapporo', 'Fukuoka', 'Sendai', 'Hiroshima', 'Yokohama', 'Kanazawa', 'Niigata', 'Kumamoto', 'Saitama', 'Kawasaki', 'Korea', 'Seoul', 'Taiwan', 'Kaohsiung', 'Taipei', 'Hong Kong', 'Malaysia', 'Kuala Lumpur', 'Singapore', 'Thailand', 'Bangkok', 'Philippines', 'Manila', 'Indonesia', 'Jakarta'];
const OCEANIA_KEYWORDS = ['Australia', 'Melbourne', 'Sydney', 'Brisbane', 'Perth', 'Adelaide', 'New Zealand', 'Auckland', 'Wellington'];

function classifyRegion(e: ConcertEntry): Region {
  if (e.buckets?.includes('key-festivals')) return 'festival';
  const state = (e.state || '').toUpperCase();
  if (NA_STATES.has(state) || CA_PROVS.has(state) || MX_STATES.has(state)) return 'na';
  const haystack = `${e.venue || ''} ${e.city || ''} ${e.state || ''} ${e.country || ''} ${e.name || ''} ${e.description || ''}`.toLowerCase();
  for (const kw of EU_KEYWORDS) { if (haystack.includes(kw.toLowerCase())) return 'eu'; }
  for (const kw of OCEANIA_KEYWORDS) { if (haystack.includes(kw.toLowerCase())) return 'oceania'; }
  for (const kw of ASIA_KEYWORDS) { if (haystack.includes(kw.toLowerCase())) return 'asia'; }
  return 'japan'; // default — most J-bucket entries without other markers are JP
}

function isVisible(e: ConcertEntry): boolean {
  return e.date >= sevenDaysAgoISO;
}

function entryMatchesBand(entry: ConcertEntry, matchNames: string[]): boolean {
  if (entry.isRelease) return false;
  if (!entry.bands || entry.bands.length === 0) return false;
  const norm = (s: string) => s.toLowerCase().replace(/[\s._\-]+/g, '').replace(/✅/g, '').trim();
  const wanted = matchNames.map(norm);
  return entry.bands.some((b) => {
    const nb = norm(b);
    return wanted.some((w) => nb === w || nb.startsWith(w) || w.startsWith(nb));
  });
}

function fmtDate(iso: string, endIso?: string): string {
  const d = new Date(iso + 'T00:00:00Z');
  const month = d.toLocaleString('en-US', { month: 'short', timeZone: 'UTC' }).toUpperCase();
  const day = d.getUTCDate();
  if (endIso && endIso !== iso) {
    const d2 = new Date(endIso + 'T00:00:00Z');
    return `${month} ${day}-${d2.getUTCDate()}`;
  }
  return `${month} ${day}`;
}

function fmtDateShort(iso: string): string {
  const d = new Date(iso + 'T00:00:00Z');
  return d.toLocaleString('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' });
}

type BandRegionRow = { dateLabel: string; iso: string; venue: string; city: string; note?: string; past: boolean };
type BandRegionBlock = { region: Region; rows: BandRegionRow[] };
type Band = BandDef & { regions: BandRegionBlock[]; totalCount: number };

const regionLabels: Record<Region, string> = {
  japan: 'JAPAN',
  na: 'NORTH AMERICA',
  eu: 'EUROPE',
  asia: 'ASIA',
  oceania: 'AUSTRALIA / OCEANIA',
  festival: 'FESTIVALS',
};

const regionOrder: Region[] = ['japan', 'na', 'eu', 'asia', 'oceania', 'festival'];

const bands: Band[] = bandDefs.map((bd) => {
  const matched = allEntries
    .filter((e) => entryMatchesBand(e, bd.matchNames))
    .filter(isVisible)
    .sort((a, b) => a.date.localeCompare(b.date));
  const byRegion = new Map<Region, BandRegionRow[]>();
  for (const e of matched) {
    const r = classifyRegion(e);
    const cityState = e.state ? `${e.city ?? ''} ${e.state}`.trim() : (e.city ?? '');
    const row: BandRegionRow = {
      dateLabel: fmtDate(e.date, e.endDate),
      iso: e.date,
      venue: e.venue || '',
      city: cityState,
      note: e.description || undefined,
      past: e.date < todayISO,
    };
    if (!byRegion.has(r)) byRegion.set(r, []);
    byRegion.get(r)!.push(row);
  }
  const regions: BandRegionBlock[] = regionOrder
    .filter((r) => byRegion.has(r))
    .map((r) => ({ region: r, rows: byRegion.get(r)! }));
  return { ...bd, regions, totalCount: matched.length };
});

// --- Per-region groups (NA, EU, Asia/Oceania) ---
type RegionEvent = { dateLabel: string; iso: string; band: string; bandClass: string; venue: string; city: string; past: boolean };

function bandClassFor(name: string): string {
  const lower = name.toLowerCase().replace(/[\s.\-]/g, '');
  if (lower.includes('lovebites')) return 'lovebites';
  if (lower.includes('bandmaid')) return 'bandmaid';
  if (lower.includes('babymetal')) return 'babymetal';
  if (lower.includes('hanabie')) return 'hanabie';
  if (lower.includes('metalverse')) return 'metalverse';
  if (lower.includes('nemophila')) return 'nemophila';
  if (lower.includes('zilqy')) return 'zilqy';
  if (lower.includes('rollingquartz')) return 'rq';
  if (lower.includes('jiluka')) return 'jiluka';
  if (lower.includes('trident')) return 'trident';
  if (lower.includes('bridear')) return 'bridear';
  if (lower.includes('ladybaby')) return 'ladybaby';
  return 'default';
}

function buildRegionEvents(region: Region | 'multi-na' | 'multi-eu' | 'multi-asia-oc'): RegionEvent[] {
  const matching = allEntries
    .filter((e) => !e.isRelease)
    .filter(isVisible)
    .filter((e) => bandDefs.some((bd) => entryMatchesBand(e, bd.matchNames)))
    .filter((e) => {
      const r = classifyRegion(e);
      if (region === 'multi-na') return r === 'na';
      if (region === 'multi-eu') return r === 'eu';
      if (region === 'multi-asia-oc') return r === 'asia' || r === 'oceania';
      return r === region;
    })
    .sort((a, b) => a.date.localeCompare(b.date));

  return matching.map((e) => {
    const bandLabel = (e.bands ?? []).filter((b) => b).join(' / ') || '—';
    const cityState = e.state ? `${e.city ?? ''} ${e.state}`.trim() : (e.city ?? '');
    return {
      dateLabel: fmtDateShort(e.date),
      iso: e.date,
      band: bandLabel,
      bandClass: bandClassFor(bandLabel),
      venue: e.venue || '',
      city: cityState,
      past: e.date < todayISO,
    };
  });
}

const naEvents = buildRegionEvents('multi-na');
const euEvents = buildRegionEvents('multi-eu');
const asiaOcEvents = buildRegionEvents('multi-asia-oc');

// --- Static editorial: festival cards ---
type FestivalCard = { title: string; meta: string; body: string };
const fests: FestivalCard[] = [
  { title: 'Summer Sonic 2026', meta: 'Aug 14-16 · Chiba + Osaka, Japan', body: '25th anniversary. <span class="jmg-hl">BABYMETAL curating "SONIC METAL STAGE"</span> at both venues (15th anniversary). METALVERSE likely. Headliners: The Strokes, L\'Arc-en-Ciel, Jamiroquai.' },
  { title: 'Wacken Open Air 2026', meta: 'Jul 29 - Aug 1 · Wacken, Germany', body: '<span class="jmg-hl">LOVEBITES + BROKEN BY THE SCREAM confirmed</span>. The world\'s biggest heavy metal festival. 85,000+ attendees.' },
  { title: 'Download Festival 2026', meta: 'Jun 10-14 · Donington Park, UK', body: 'Legendary UK metal festival.' },
  { title: 'Rock am Ring / Rock im Park', meta: 'Jun 5-7 · Germany', body: 'Twin festivals in Nurburgring and Nuremberg.' },
  { title: 'Sweden Rock Festival', meta: 'Jun 3 · Solvesborg, Sweden', body: 'Headline-tier European metal festival.' },
  { title: 'Graspop Metal Meeting', meta: 'Jun 18-21 · Dessel, Belgium', body: 'One of Europe\'s premier metal festivals.' },
  { title: 'Tons Of Rock', meta: 'Jun 24 · Oslo, Norway', body: 'Scandinavian heavy festival.' },
  { title: 'COPENHELL', meta: 'Jun 27 · Copenhagen, Denmark', body: 'Scandinavian metal fest.' },
  { title: 'Monster Energy Aftershock', meta: 'Oct 3 · Sacramento, CA', body: 'Major US festival at Discovery Park.' },
  { title: 'UNLUCKY FES 2026', meta: 'Jun 6 · Kawasaki, Japan', body: 'NEMOPHILA confirmed. Multi-band festival at CLUB CITTA\'.' },
];
---

<BaseLayout
  title="Japan Global Tours 2026 | The Music Cities"
  description="Japanese metal bands touring abroad in 2026: North America, Europe, Asia/Oceania, and festival dates pulled live from the dashboard data feed."
>
  <Header title="Japan Global Tours 2026" />

  <section class="dash-hero">
    <div class="container">
      <p class="dash-hero__eyebrow">Scene Brief</p>
      <h1 class="dash-hero__title">Japan <em>Global Tours 2026</em></h1>
      <p class="dash-hero__subtitle">J-metal bands touring abroad — North America, Europe, Asia, Oceania</p>
      <p class="dash-hero__lede">
        Every confirmed date for the 13-band watch list, pulled live from concerts.json. Tour cards
        per band, then a regional breakdown — including the Nemophila NA "MY TURN" tour, Rolling
        Quartz crossing into LA / Texas, and Jiluka's summer Brick by Brick + Come and Take It Live
        stops.
      </p>
    </div>
  </section>

  <nav class="dash-tabs" aria-label="Section tabs">
    <button class="dash-tab is-active" data-target="jmg-byband" type="button">By Band</button>
    <button class="dash-tab" data-target="jmg-na" type="button">North America</button>
    <button class="dash-tab" data-target="jmg-eu" type="button">Europe</button>
    <button class="dash-tab" data-target="jmg-asia" type="button">Asia / Oceania</button>
    <button class="dash-tab" data-target="jmg-fests" type="button">Festivals</button>
  </nav>

  <main class="dash-main">
    <div class="container">

      <section id="jmg-byband" class="dash-tabpanel is-active">
        <h2 class="dash-section__title">Full Tour Schedules by Band</h2>
        <p class="dash-section__intro">Click any band to expand their complete 2026 worldwide itinerary. Dates pull live from concerts.json.</p>
        {bands.map((b) => (
          <article class={b.open ? 'jmg-band is-open' : 'jmg-band'} id={b.id}>
            <header class="jmg-band__head" data-toggle={b.id}>
              <div class="jmg-band__title">
                <div class="jmg-band__name">{b.name}</div>
                <div class="jmg-band__meta">{b.meta}</div>
              </div>
              <span class={`jmg-count jmg-count--${b.countKind}`}>{b.totalCount > 0 ? `${b.totalCount} DATE${b.totalCount === 1 ? '' : 'S'}` : (b.countKind === 'muted' ? 'NO DATES' : 'TBD')}</span>
            </header>
            <div class="jmg-band__body">
              {b.regions.length === 0 ? (
                <p class="jmg-note">No upcoming shows in the feed yet.</p>
              ) : null}
              {b.regions.map((rg) => (
                <Fragment>
                  <div class="jmg-region-label">
                    <span class={`jmg-dot jmg-dot--${rg.region}`}></span>
                    {regionLabels[rg.region]}
                  </div>
                  <table class="jmg-table">
                    <tbody>
                      {rg.rows.map((r) => (
                        <tr class={r.past ? 'jmg-row jmg-row--past' : 'jmg-row'}>
                          <td class="jmg-td-date">{r.dateLabel}</td>
                          <td class="jmg-td-venue">
                            {r.venue}
                            {r.note ? <span class="jmg-td-note"> · {r.note}</span> : null}
                          </td>
                          <td class="jmg-td-city">{r.city}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </Fragment>
              ))}
              {b.note ? <div class="jmg-note">{b.note}</div> : null}
            </div>
          </article>
        ))}
      </section>

      <section id="jmg-na" class="dash-tabpanel">
        <h2 class="dash-section__title">North America</h2>
        <p class="dash-section__intro">All confirmed US, Canada, and Mexico dates sorted chronologically.</p>
        {naEvents.length === 0 ? <p class="dash-footnote">No North America dates in the feed yet.</p> : null}
        <div class="jmg-region">
          {naEvents.map((r) => (
            <div class={r.past ? 'jmg-event jmg-event--past' : 'jmg-event'}>
              <span class="jmg-event__date">{r.dateLabel}</span>
              <span class={`jmg-event__band jmg-event__band--${r.bandClass}`}>{r.band}</span>
              <span class="jmg-event__venue">{r.venue}</span>
              <span class="jmg-event__city">{r.city}</span>
            </div>
          ))}
        </div>
      </section>

      <section id="jmg-eu" class="dash-tabpanel">
        <h2 class="dash-section__title">Europe &amp; UK</h2>
        <p class="dash-section__intro">All confirmed European dates across headline shows and festivals.</p>
        {euEvents.length === 0 ? <p class="dash-footnote">No Europe dates in the feed yet.</p> : null}
        <div class="jmg-region">
          {euEvents.map((r) => (
            <div class={r.past ? 'jmg-event jmg-event--past' : 'jmg-event'}>
              <span class="jmg-event__date">{r.dateLabel}</span>
              <span class={`jmg-event__band jmg-event__band--${r.bandClass}`}>{r.band}</span>
              <span class="jmg-event__venue">{r.venue}</span>
              <span class="jmg-event__city">{r.city}</span>
            </div>
          ))}
        </div>
      </section>

      <section id="jmg-asia" class="dash-tabpanel">
        <h2 class="dash-section__title">Asia &amp; Oceania</h2>
        <p class="dash-section__intro">Non-Japan Asian dates and Australia/NZ.</p>
        {asiaOcEvents.length === 0 ? <p class="dash-footnote">No Asia/Oceania dates outside Japan in the feed yet.</p> : null}
        <div class="jmg-region">
          {asiaOcEvents.map((r) => (
            <div class={r.past ? 'jmg-event jmg-event--past' : 'jmg-event'}>
              <span class="jmg-event__date">{r.dateLabel}</span>
              <span class={`jmg-event__band jmg-event__band--${r.bandClass}`}>{r.band}</span>
              <span class="jmg-event__venue">{r.venue}</span>
              <span class="jmg-event__city">{r.city}</span>
            </div>
          ))}
        </div>
      </section>

      <section id="jmg-fests" class="dash-tabpanel">
        <h2 class="dash-section__title">Major Festivals</h2>
        <p class="dash-section__intro">Multi-day events where you can catch these bands (and many more).</p>
        {fests.map((f) => (
          <div class="jmg-festival">
            <h3>{f.title} <span class="jmg-festival__meta">{f.meta}</span></h3>
            <p set:html={f.body}></p>
          </div>
        ))}
      </section>

      <p class="dash-footnote" style="margin-top:2rem;">Dates pull live from concerts.json. Past shows trim to last 7 days. Stay heavy, wherever you are.</p>
    </div>
  </main>

  <Footer />

  <script is:inline>
    (function () {
      function activate(target) {
        document.querySelectorAll('.dash-tabpanel').forEach(function (p) { p.classList.remove('is-active'); });
        document.querySelectorAll('.dash-tab').forEach(function (t) { t.classList.remove('is-active'); });
        var panel = document.getElementById(target);
        if (panel) panel.classList.add('is-active');
        var btn = document.querySelector('.dash-tab[data-target="' + target + '"]');
        if (btn) btn.classList.add('is-active');
      }
      document.querySelectorAll('.dash-tab').forEach(function (t) {
        t.addEventListener('click', function () { activate(t.getAttribute('data-target')); });
      });
      document.querySelectorAll('.jmg-band__head').forEach(function (h) {
        h.addEventListener('click', function () {
          var id = h.getAttribute('data-toggle');
          if (!id) return;
          var card = document.getElementById(id);
          if (card) card.classList.toggle('is-open');
        });
      });
    })();
  </script>
</BaseLayout>
