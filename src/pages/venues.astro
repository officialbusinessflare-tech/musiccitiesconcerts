---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { ConcertsDataFile, ConcertEntry } from '../lib/types';

// Build-time JSON import. concerts.json is regenerated nightly by the
// scheduled function committing back to the repo.
import concertsData from '../../concerts.json';

type GoToVenue = {
  city: string;
  venueName: string;
  address: string;
  why: string;
  // Substring used to match the venue field in concerts.json (case-insensitive).
  match: string;
};

// Kevin's go-to venue per city. Manually curated. One per city, the room
// his coverage is anchored on.
const goToVenues: GoToVenue[] = [
  {
    city: 'Tampa, FL',
    venueName: 'Brass Mug',
    address: '1450 Bush Blvd, Tampa, FL 33612',
    why: "Tampa's metal living room. Smash 'Em Up release party HQ; reliable bills, low cover, real crowd.",
    match: 'brass mug',
  },
  {
    city: 'Orlando, FL',
    venueName: 'Conduit',
    address: '6700 Aloma Ave #200, Winter Park, FL 32792',
    why: "Orlando's J-metal anchor. Where Nemophila and Lovebites land when they tour the southeast.",
    match: 'conduit',
  },
  {
    city: 'Fort Lauderdale, FL',
    venueName: 'Culture Room',
    address: '3045 N Federal Hwy, Fort Lauderdale, FL 33306',
    why: "South Florida's veteran metal room. Culture Room books hard across metal/hardcore/rock — where the touring bill lands when it hits Broward County.",
    match: 'culture room',
  },
  {
    city: 'Miami, FL',
    venueName: 'Las Rosas',
    address: '2898 NW 7th Ave, Miami, FL 33127',
    why: "Miami's rock dive. Free shows, local bills, no pretense — the right antidote to South Beach.",
    match: 'las rosas',
  },
  {
    city: 'Austin, TX',
    venueName: 'Come and Take It Live',
    address: '2015 E Riverside Dr, Austin, TX 78741',
    why: 'The independent metal room in the Texas capital. Holds 1,000, books hard.',
    match: 'come and take it live',
  },
  {
    city: 'San Diego, CA',
    venueName: 'Brick by Brick',
    address: '1130 Buenos Ave, San Diego, CA 92110',
    why: "SoCal's underground metal stronghold. 350-cap, every tour worth catching cycles through.",
    match: 'brick by brick',
  },
  {
    city: 'West Hollywood, CA',
    venueName: 'Whisky a Go Go',
    address: '8901 Sunset Blvd, West Hollywood, CA 90069',
    why: "The Strip's birthplace of metal. Still books real bills six nights a week — history you can walk into.",
    match: 'whisky',
  },
];

const data = concertsData as ConcertsDataFile;
const today = new Date().toISOString().slice(0, 10);

// All non-release, future-dated entries with a venue field.
const upcoming: ConcertEntry[] = (data.entries ?? []).filter((e) => {
  if (e.isRelease) return false;
  if (!e.venue) return false;
  const compareDate = e.endDate ?? e.date;
  return compareDate >= today;
});

function nextThreeAt(matchStr: string): ConcertEntry[] {
  const needle = matchStr.toLowerCase();
  return upcoming
    .filter((e) => (e.venue ?? '').toLowerCase().includes(needle))
    .sort((a, b) => a.date.localeCompare(b.date))
    .slice(0, 3);
}

const cityCards = goToVenues.map((v) => ({
  ...v,
  shows: nextThreeAt(v.match),
}));

function formatShowDate(iso: string): string {
  const [y, m, d] = iso.split('-').map((n) => parseInt(n, 10));
  const dt = new Date(Date.UTC(y, m - 1, d));
  return dt.toLocaleDateString('en-US', {
    weekday: 'short',
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'UTC',
  });
}
---

<BaseLayout
  title="Go-To Venues | The Music Cities"
  description="The venues Kevin actually anchors his coverage on. One per city — the next time a band you care about is in town, this is where they're playing."
>
  <Header />

  <section class="venues-hero">
    <div class="container">
      <p class="venues-hero__eyebrow">The Rooms</p>
      <h1 class="venues-hero__title">Go-To <em>Venues</em></h1>
      <p class="venues-hero__lede">
        The venues Kevin actually anchors his coverage on. One per city. The next
        time a band you care about is in town, this is where they're playing.
      </p>
    </div>
  </section>

  <main class="venues-main">
    <div class="container">
      <div class="venues-grid">
        {cityCards.map((card) => (
          <article class="venues-card">
            <header class="venues-card__head">
              <p class="venues-card__city">{card.city}</p>
              <h2 class="venues-card__venue">{card.venueName}</h2>
              <p class="venues-card__address">{card.address}</p>
            </header>

            <p class="venues-card__why">{card.why}</p>

            <section class="venues-card__shows">
              <h3 class="venues-card__shows-title">Next 3 shows at this venue</h3>
              {card.shows.length === 0 ? (
                <p class="venues-card__empty">No shows currently scheduled — check back.</p>
              ) : (
                <ul class="venues-card__show-list">
                  {card.shows.map((s) => (
                    <li class="venues-card__show">
                      <span class="venues-card__show-date">{formatShowDate(s.date)}</span>
                      <span class="venues-card__show-name">
                        {s.ticketUrl ? (
                          <a href={s.ticketUrl} rel="noopener noreferrer">{s.name}</a>
                        ) : (
                          s.name
                        )}
                      </span>
                    </li>
                  ))}
                </ul>
              )}
            </section>
          </article>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
