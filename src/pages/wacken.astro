type Slot = { time: string; band: string; meta?: string; why: string; tier: Tier };
type Conflict = { title: string; body: string; pick: string };
type DayBlock = { head: string; slots: Slot[]; conflicts?: Conflict[]; footnote?: string };

const days: DayBlock[] = [
  {
    head: 'WEDNESDAY JULY 29',
    slots: [
      { time: '12:00-13:00', band: 'Broken By The Scream', meta: 'Louder stage', why: 'Tier 1. Day 1 noon slot on Louder. Metal Blade signing this year and the M&G is confirmed at The Dome on Aug 2 — this is the festival warm-up for that. Get to the rail — narrow set.', tier: 't1' },
      { time: '16:00-17:00', band: 'Lovebites', meta: 'Faster stage (day 1 opener)', why: 'Tier 1. Day 1 opener on the Faster main stage — get to the rail early. Festival set ahead of the O2 show. LOVEBITES also plays a FREE warm-up at Free & Easy Festival in Munich on Mon Jul 27.', tier: 't1' },
      { time: '21:00-22:30', band: 'Lacuna Coil', meta: 'Louder stage', why: 'Tier 2, newly added. No conflict with anything else you want.', tier: 't2' },
      { time: '22:45-00:00', band: 'Rose Tattoo', meta: 'W:E:T stage', why: 'Optional. Starts as Lacuna Coil ends, slight overlap on the tail. Easy walk if you want both.', tier: 't2' },
      { time: 'Open', band: 'Discovery windows', why: 'Visions of Atlantis 13:30, Thundermother 15:15 and The Gathering 18:45 on Louder are worth catching between anchors. Kadavar 21:15 on Headbangers if you skip Lacuna Coil.', tier: 'gap' },
    ],
  },
  {
    head: 'THURSDAY JULY 30',
    slots: [
      { time: '16:15-17:30', band: 'Uli Jon Roth', meta: 'Harder stage', why: 'Tier 2. The Scorpions Virgin Killer Reborn 50th anniversary set with special guests. This is your Scorpions content.', tier: 't2' },
      { time: '17:30-18:45', band: 'Yngwie Malmsteen', meta: 'Faster stage', why: 'Tier 1. See conflict note below — the handoff from Roth is tight.', tier: 't1' },
      { time: '19:00-20:15', band: 'Europe', meta: 'Harder stage', why: 'Tier 2. Clean slot right after Yngwie.', tier: 't2' },
      { time: '20:30-22:00', band: 'Savatage', meta: 'Faster stage', why: 'Tier 2, Florida band. Overlaps only the tail of Europe.', tier: 't2' },
      { time: '22:15-00:00', band: 'Def Leppard', meta: 'Harder stage', why: 'Headliner. Day 2 closer. Clean, starts after Savatage.', tier: 'headliner' },
    ],
    conflicts: [
      {
        title: 'Conflict - Uli Jon Roth vs Yngwie Malmsteen',
        body: 'Roth 16:15-17:30 (Harder) into Yngwie 17:30-18:45 (Faster). Back to back with zero gap and a stage change.',
        pick: "Pick: see both. Watch Roth from stage right near the Faster side exit, leave at 17:20, walk to Faster. You lose Roth's last song and Yngwie's intro. If you only pick one, take Yngwie — he's your Tier 1. Roth's set repeats thematically through the Scorpions material you can catch elsewhere.",
      },
    ],
  },
  {
    head: 'FRIDAY JULY 31 - the heavy day',
    slots: [
      { time: '17:00-18:15', band: 'Black Label Society', meta: 'Faster stage', why: 'Tier 2. Ends as Saxon starts, slight tail overlap.', tier: 't2' },
      { time: '18:15-19:30', band: 'Saxon', meta: 'Harder stage', why: 'Tier 2. Walk over after BLS.', tier: 't2' },
      { time: '19:45-21:15', band: 'In Flames', meta: 'Faster stage', why: 'Tier 2. Conflicts with Hatebreed, see note.', tier: 't2' },
      { time: '21:30-23:00', band: 'Judas Priest', meta: 'Harder stage', why: 'Headliner and Tier 1. Starts right as In Flames ends. Clean handoff, this is the must see of the night.', tier: 'headliner' },
      { time: '23:15-00:45', band: 'Running Wild', meta: 'Faster stage', why: "Tier 2, farewell, last show ever. Overlaps Priest's final 45 minutes. See note.", tier: 't2' },
      { time: '01:00-02:15', band: 'Sepultura', meta: 'Harder stage', why: 'Tier 2, last German festival show. Clean, after Running Wild.', tier: 't2' },
    ],
    conflicts: [
      {
        title: 'Conflict - In Flames vs Hatebreed',
        body: 'In Flames 19:45-21:15 (Faster) overlaps Hatebreed 19:00-20:15 (Louder).',
        pick: "Pick: In Flames. Both are Tier 2 but In Flames is on the path to Priest and the bigger set. Catch the first 30 minutes of Hatebreed then move to Faster, you only miss In Flames' opening two songs.",
      },
      {
        title: 'Conflict - Judas Priest tail vs Running Wild farewell',
        body: 'Priest 21:30-23:00 (Harder), Running Wild 23:15-00:45 (Faster). Running Wild starts 15 minutes after Priest ends, so no real overlap. The tension is energy and stamina, not time.',
        pick: 'Pick: full Priest, then full Running Wild, then Sepultura. It works on paper. This is a three headliner night ending at 02:15. Eat and hydrate before 21:00 because there is no break after.',
      },
    ],
  },
  {
    head: 'SATURDAY AUGUST 1 - final day',
    slots: [
      { time: '16:15-17:45', band: 'Lamb of God', meta: 'Harder stage', why: 'Tier 2. Clean afternoon slot.', tier: 't2' },
      { time: '19:00-20:30', band: 'Arch Enemy', meta: 'Harder stage', why: 'Tier 1. Lauren Hart era, Leadership episode thesis. No conflict, this is a clean must see.', tier: 't1' },
      { time: '20:45-22:30', band: 'Powerwolf', meta: 'Faster stage', why: 'Headliner. Starts right as Arch Enemy ends. Clean handoff, walk from Harder to Faster.', tier: 'headliner' },
      { time: '23:00-00:45', band: 'Sabaton', meta: 'Harder stage', why: 'Headliner. Festival closer. Starts after Powerwolf ends, clean.', tier: 'headliner' },
      { time: 'Open', band: 'Discovery windows', why: 'Crimson Glory 14:00 on Headbangers is the one Tier 2 you might still catch earlier in the day. Triptykon 22:45 on Louder overlaps Powerwolf, skip it, you have a M&G slot with them instead.', tier: 'gap' },
    ],
    footnote: 'Saturday is the cleanest day. Arch Enemy into Powerwolf into Sabaton is three straight headline grade sets with zero conflicts. No hard choices.',
  },
];

const fullLineup: { name: string; tier?: Tier }[] = [
  { name: 'Def Leppard', tier: 'headliner' }, { name: 'Judas Priest', tier: 'headliner' }, { name: 'Powerwolf', tier: 'headliner' }, { name: 'Sabaton', tier: 'headliner' },
  { name: '5th Avenue' }, { name: '9mm Headshot' }, { name: 'Ad Infinitum' }, { name: 'Airbourne' }, { name: 'Alcest' }, { name: 'Alestorm' }, { name: 'Alfahanne' }, { name: 'Alien Ant Farm' }, { name: 'Alien Rockin Explosion' }, { name: 'Allt' }, { name: 'Anaal Nathrakh' },
  { name: 'Animals As Leaders', tier: 't2' }, { name: 'Angelus Apatrida' }, { name: 'Any Given Day' }, { name: 'Arch Enemy', tier: 't1' }, { name: 'Arroganz' }, { name: 'Asrock' }, { name: 'Battlecreek' }, { name: 'Bear McCreary' }, { name: 'Blaas Of Glory' },
  { name: 'Black Label Society', tier: 't2' }, { name: 'Black Tish' }, { name: 'Bleed From Within' }, { name: 'Blood Command' }, { name: 'Blood Fire Death' }, { name: 'Blood Red Throne' },
  { name: 'Broken By The Scream', tier: 't1' }, { name: 'Brunhilde' }, { name: 'Castle Rat' }, { name: 'Chaosbay' }, { name: 'Corrosion Of Conformity' }, { name: 'Craft' }, { name: 'Crematory' },
  { name: 'Crimson Glory', tier: 't2' }, { name: 'Cruachan' }, { name: 'Crypt Sermon' }, { name: 'Cursed Abyss' }, { name: 'Danko Jones' }, { name: 'Deafheaven' }, { name: 'Diabolisches Werk' }, { name: 'Dieter Birr' }, { name: 'Dirty Shirt' }, { name: 'Divlje Jagode' }, { name: 'Dritte Wahl' }, { name: 'Dubioza Kolektiv' }, { name: 'Einherjer' }, { name: 'Electric Bassboy' }, { name: 'Elakelainen' },
  { name: 'Emperor', tier: 't2' }, { name: 'Employed To Serve' }, { name: 'Europe', tier: 't2' }, { name: 'Evil Jared X Krogi' }, { name: 'Expellow' }, { name: 'Faun' }, { name: 'Finsterforst' }, { name: 'Firespawn' }, { name: 'Fit For An Autopsy' }, { name: 'Focus' }, { name: 'Future Palace' }, { name: 'Grand Magus' }, { name: 'Guilt Trip' }, { name: 'Gutalax' }, { name: 'H-Blockx' },
  { name: 'Hatebreed', tier: 't2' }, { name: 'Hamatom' }, { name: 'Heartless Human Harvest' }, { name: 'Heavysaurus' },
  { name: 'In Flames', tier: 't2' }, { name: 'Insanity Alert' }, { name: 'Kadavar' }, { name: 'Karbholz' }, { name: 'Kupfergold' },
  { name: 'Lacuna Coil', tier: 't2' }, { name: 'Lamb of God', tier: 't2' }, { name: 'Lovebites', tier: 't1' }, { name: 'Luna Kills' }, { name: 'Mambo Kurt' }, { name: 'Manntra' }, { name: 'Mantar' }, { name: 'Maschine' }, { name: 'Metaklapa' }, { name: 'Minotaurus' }, { name: 'Mr Hurley und Die Pulveraffen' }, { name: 'Nevermore' }, { name: 'Of Mice and Men' }, { name: 'Orbit Culture' }, { name: 'Paleface Swiss' }, { name: 'Paradise Lost' }, { name: 'Pig Destroyer' }, { name: 'President' }, { name: 'Rose Tattoo' },
  { name: 'Running Wild', tier: 't2' }, { name: 'Sagenbringer' }, { name: 'Savatage', tier: 't2' }, { name: 'Saviourself' }, { name: 'Saxon', tier: 't2' }, { name: 'Sepultura', tier: 't2' }, { name: 'Skyline' }, { name: 'Stonem' }, { name: 'Subway to Sally' }, { name: 'Temple Of The Absurd' }, { name: 'Ten56' }, { name: 'The Gathering' }, { name: 'The Hardkiss' }, { name: 'The Limit' }, { name: 'The Other' }, { name: 'Thrown' },
  { name: 'Thundermother', tier: 't2' }, { name: 'Trold' }, { name: 'Tryptikon' }, { name: 'Tuxedoo' },
  { name: 'Uli Jon Roth', tier: 't2' }, { name: 'Unzucht' }, { name: 'Velvet Rush' }, { name: 'Visions of Atlantis' }, { name: 'Wacken Firefighters' }, { name: 'Wustenberg' }, { name: 'Wytch Hazel' }, { name: 'Year Of The Goat' },
  { name: 'Yngwie Malmsteen', tier: 't1' }, { name: 'Zeltinger Band' },
];

function pillClass(kind?: string) {
  switch (kind) {
    case 'confirmed': return 'wkn-pill wkn-pill--confirmed';
    case 'pending': return 'wkn-pill wkn-pill--pending';
    case 'farewell': return 'wkn-pill wkn-pill--farewell';
    default: return 'wkn-pill';
  }
}

// YouTube content — silent fallback so a missing file doesnt break the build.
let ytData: any = {
  channels: { tmc: { recentLongform: [], recentShorts: [] }, radio: { recentLongform: [], recentShorts: [] } },
  playlists: {},
};
try {
  ytData = (await import("../../public/youtube-content.json")).default ?? ytData;
} catch (err) {}
const bucketPlaylist = ytData?.playlists?.["european-metal"] ?? [];
const radioShorts = ytData?.channels?.radio?.recentShorts ?? [];
---

<BaseLayout
  title="Wacken 2026 Dashboard | The Music Cities"
  description="The 35th anniversary edition of Wacken Open Air, July 29 to August 1, 2026 — lineup, priority tiers, conflict picks, Metal Battle, and our day-by-day challenge."
>
  <Header />

  <section class="dash-hero">
    <div class="container">
      <p class="dash-hero__eyebrow">Festival Brief</p>
      <h1 class="dash-hero__title">Wacken <em>2026</em></h1>
      <p class="dash-hero__subtitle">35th anniversary edition — July 29 to August 1, 2026 — Wacken, Germany</p>
      <p class="dash-hero__lede">
        ~140 confirmed bands, four headliners, the Scorpions Virgin Killer Reborn 50th anniversary set,
        Running Wild's farewell, Sepultura's last German festival show — and a tier-coded day-by-day
        plan with the conflicts already picked.
      </p>
      <div class="wkn-countdown" id="wkn-countdown" aria-live="polite"></div>
    </div>
  </section>

  <VideoStrip title="Recent European Metal Episodes" videos={bucketPlaylist} channelBadge="TMC" />

  <main class="dash-main">
    <div class="container">

      <section class="dash-section">
        <h2 class="dash-section__title">Festival window</h2>
        <dl class="wkn-meta">
          <div><dt>Lineup size</dt><dd>~140 confirmed bands plus support</dd></div>
          <div><dt>Headliners</dt><dd>Def Leppard, Judas Priest, Powerwolf, Sabaton</dd></div>
          <div><dt>Special show</dt><dd>Scorpions Virgin Killer Reborn 50th anniversary, featuring Uli Jon Roth and special guests</dd></div>
          <div><dt>Final shows</dt><dd>Running Wild farewell, Sepultura last German festival show</dd></div>
        </dl>
      </section>

      <section class="dash-section">
        <h2 class="dash-section__title">Priority tiers</h2>
        <div class="wkn-tier-grid">
          <div class="wkn-tier wkn-tier--headliners">
            <div class="wkn-tier__label">Headliners</div>
            <ul>
              {headliners.map((b) => (
                <li>{b.name}{b.pill ? <span class={pillClass(b.pillKind)}>{b.pill}</span> : null}</li>
              ))}
            </ul>
          </div>
          <div class="wkn-tier wkn-tier--t1">
            <div class="wkn-tier__label">Tier 1 must see</div>
            <ul>
              {tier1.map((b) => (
                <li>{b.name}{b.pill ? <span class={pillClass(b.pillKind)}>{b.pill}</span> : null}</li>
              ))}
            </ul>
          </div>
          <div class="wkn-tier wkn-tier--t2">
            <div class="wkn-tier__label">Tier 2 high interest</div>
            <ul>
              {tier2.map((b) => (
                <li>{b.name}{b.pill ? <span class={pillClass(b.pillKind)}>{b.pill}</span> : null}</li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <section class="dash-section">
        <h2 class="dash-section__title">Metal Battle 2026 — national winners watch</h2>
        <p class="dash-section__intro">
          Wacken Metal Battle pits one band from each participating country in a Headbangers Stage tournament
          during the festival. Confirmed national champions get a Wacken slot. Tracking the US closely
          because Kevin attended the US National Final on June 13 in San Diego.
        </p>
        <dl class="wkn-meta">
          <div><dt>US National Final</dt><dd>June 13, 2026, Brick By Brick, San Diego — Kevin attended</dd></div>
          <div><dt>US WINNER</dt><dd class="wkn-meta__green">GANNONDORF — San Diego, avant-garde black metal. The hometown band took it. Took judges and crowd. Judges: Rod Kukla (Silver Lining Music), Martin Koller (Prophecy Productions / SPKR Media), Kelly McLauchlin (Pessimist). Prize: WOA slot, full backline, $1,000 USD flight stipend, VIP camping.</dd></div>
          <div><dt>USA slot at Wacken</dt><dd class="wkn-meta__green">OPENING SLOT of the entire tournament. Wednesday July 29, 11:25 to 12:05, Headbangers Stage.</dd></div>
          <div><dt>Japan</dt><dd>Given By The Flames (gothic metalcore). Thursday July 30, 14:20 to 14:40, Headbangers Stage.</dd></div>
          <div><dt>Korea / South Korea</dt><dd>Not participating in 2026.</dd></div>
          <div><dt>Tournament progress</dt><dd>21 of 31 country slots named (USA added June 13). Finland national final ran June 17 to 20 at Nummirock with finalists Fatal Effect, Wagtails, Where's My Bible — winner not yet posted. Philippines, Germany, UK, Australia, Switzerland still pending.</dd></div>
        </dl>
        <div class="wkn-table-wrap">
          <table class="wkn-table">
            <thead><tr><th>Day</th><th>Time</th><th>Country</th><th>Band</th><th>Stage</th></tr></thead>
            <tbody>
              {metalBattle.map((r) => (
                <tr class={r.highlight ? `wkn-row--${r.highlight}` : undefined}>
                  <td>{r.day}</td><td>{r.time}</td><td>{r.country}</td><td>{r.band}</td><td>{r.stage}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="dash-footnote">
          Source: wacken.com running order and metal-battle.com 2026 grid. Unlabeled Headbangers slots
          (Seers of Light, Human Nebula, Dead Memories, Witchlords, Invasion, Death Row, Days of Ruin)
          are likely additional national entries whose country tags will be confirmed as remaining national
          finals wrap up. The international Metal Battle final rounds run Wednesday and Thursday on the
          Headbangers Stage. About 30 national champions compete for the worldwide title.
        </p>
      </section>

      <section class="dash-section">
        <h2 class="dash-section__title">The Music Cities Challenge</h2>
        <p class="dash-section__intro">
          Built from the first running order published May 20, 2026. Set times are subject to change.
          Slots flagged for you are priority tier bands. Times in 24 hour. Stage in parentheses.
        </p>
        <div class="wkn-legend">
          <span><i class="wkn-swatch wkn-swatch--headliner"></i> Headliner</span>
          <span><i class="wkn-swatch wkn-swatch--t1"></i> Tier 1 must see</span>
          <span><i class="wkn-swatch wkn-swatch--t2"></i> Tier 2 high interest</span>
          <span><i class="wkn-swatch wkn-swatch--gap"></i> Open block, discovery or rest</span>
        </div>

        {days.map((d) => (
          <div class="wkn-day">
            <div class="wkn-day__head">{d.head}</div>
            {d.slots.map((s) => (
              <div class={`wkn-slot wkn-slot--${s.tier}`}>
                <div class="wkn-slot__time">{s.time}</div>
                <div class="wkn-slot__body">
                  <div class="wkn-slot__band">{s.band}</div>
                  {s.meta ? <div class="wkn-slot__meta">{s.meta}</div> : null}
                  <div class="wkn-slot__why">{s.why}</div>
                </div>
              </div>
            ))}
            {d.conflicts?.map((c) => (
              <div class="wkn-conflict">
                <div class="wkn-conflict__title">{c.title}</div>
                <div class="wkn-conflict__body">{c.body}</div>
                <div class="wkn-conflict__pick">{c.pick}</div>
              </div>
            ))}
            {d.footnote ? <div class="dash-footnote">{d.footnote}</div> : null}
          </div>
        ))}

        <p class="dash-footnote">
          Summary of hard choices: Thursday Roth into Yngwie is the only true clash and it is solvable
          by leaving Roth early. Friday In Flames vs Hatebreed split the first half hour. Everything
          else chains cleanly. Your four headliners are all catchable in full. All five Tier 1 bands
          are catchable in full.
        </p>
      </section>

      <section class="dash-section">
        <h2 class="dash-section__title">Meet and greet schedule</h2>
        <dl class="wkn-meta">
          <div><dt>Status</dt><dd>Wacken official schedule still not released as of June 22. Mid-July rollout has not started.</dd></div>
          <div><dt>Confirmed slots so far</dt><dd>Mantar, Triptykon (unchanged since May)</dd></div>
