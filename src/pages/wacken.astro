  { day: 'Thu Jul 30', time: '11:50-12:10', country: 'Malta', band: 'HAINE', stage: 'W:E:T' },
  { day: 'Thu Jul 30', time: '12:15-12:35', country: 'Slovakia', band: 'GAGOR', stage: 'W:E:T' },
  { day: 'Thu Jul 30', time: '13:05-13:25', country: 'Chile', band: 'FORCE', stage: 'Headbangers' },
  { day: 'Thu Jul 30', time: '13:30-14:10', country: 'Philippines', band: 'TBA', stage: 'W:E:T' },
  { day: 'Thu Jul 30', time: '13:55-14:15', country: 'India', band: 'Midhaven', stage: 'Headbangers' },
