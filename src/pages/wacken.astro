---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import VideoStrip from '../components/VideoStrip.astro';

/**
 * /wacken — Wacken 2026 editorial dashboard.
 *
 * Built from the Wacken_Dashboard_20260622 brief. The Music Cities Challenge section
 * is INTENTIONALLY PUBLIC — the "Music Cities Challenge" framing is the
 * editorial voice The Music Cities publishes under. Do not strip it.
 *
 * Tier color codes: headliner/tier1/tier2/tier3 surface through the .wkn-*
 * classes (see styles/global.css). Conflict callouts and "Pick:"
 * recommendations are deliberately preserved.
 *
 * The live countdown ticker is wired as an inline script at the bottom.
 */

type Tier = 'headliner' | 't1' | 't2' | 'gap';

type PriorityItem = { name: string; pill?: string; pillKind?: 'default' | 'confirmed' | 'pending' | 'farewell' };

const headliners: PriorityItem[] = [
  { name: 'Def Leppard' },
  { name: 'Judas Priest', pill: 'Tier 1' },
  { name: 'Powerwolf' },
  { name: 'Sabaton' },
];

const tier1: PriorityItem[] = [
  { name: 'Lovebites', pill: 'O2 M&G Aug 3', pillKind: 'confirmed' },
  { name: 'Arch Enemy', pill: 'Lauren Hart era' },
  { name: 'Broken By The Scream', pill: 'Dome M&G Aug 2', pillKind: 'confirmed' },
  { name: 'Yngwie Malmsteen' },
  { name: 'Judas Priest' },
];

const tier2: PriorityItem[] = [
  { name: 'Scorpions Virgin Killer Reborn', pill: 'New', pillKind: 'confirmed' },
  { name: 'Saxon' },
  { name: 'Europe' },
  { name: 'Savatage', pill: 'FL band' },
  { name: 'Black Label Society' },
  { name: 'Lamb of God' },
  { name: 'In Flames' },
  { name: 'Running Wild', pill: 'Farewell', pillKind: 'farewell' },
  { name: 'Sepultura', pill: 'Last DE', pillKind: 'farewell' },
  { name: 'Emperor' },
  { name: 'Uli Jon Roth', pill: 'Scorpions 50' },
  { name: 'Animals As Leaders' },
  { name: 'Hatebreed' },
  { name: 'Crimson Glory' },
  { name: 'Thundermother' },
  { name: 'Lacuna Coil', pill: 'New', pillKind: 'confirmed' },
];

type BattleRow = { day: string; time: string; country: string; band: string; stage: string; highlight?: 'us' | 'jp' };

const metalBattle: BattleRow[] = [
  { day: 'Wed Jul 29', time: '11:25-12:05', country: 'USA', band: 'GANNONDORF (San Diego, avant-garde black metal) - opens the tournament', stage: 'Headbangers', highlight: 'us' },
