---
/**
 * Homepage — curated overview.
 *
 * As of the Jun 2026 architectural split, the homepage no longer renders
 * the full per-bucket scroll. Its job is to direct visitors to the right
 * bucket page. Layout, top to bottom:
 *   - Header
 *   - SceneNav (now links to top-level pages)
 *   - Hero strip ("Concerts. Releases. The scene.")
 *   - Field Trip strip (Metal London — preserved)
 *   - Coming Up Next: next 8 entries across ALL buckets
 *   - The Scenes: 6 bucket teaser tiles + a Venues tile (7 total)
 *   - Footer
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import SceneNav from '../components/SceneNav.astro';
import Footer from '../components/Footer.astro';
import ShowCard from '../components/ShowCard.astro';
import ReleaseCard from '../components/ReleaseCard.astro';
import type { BucketsConfigFile, ConcertsDataFile, ConcertEntry, BirthdaysDataFile } from '../lib/types';
import { categorize, groupByBucket } from '../lib/categorize';
import { collectKnownVenues, reparseEntry } from '../lib/parse-name';

import bucketsConfig from '../../buckets.config.json';
import concertsData from '../../concerts.json';
import birthdaysData from '../../birthdays.json';

const buckets = (bucketsConfig as BucketsConfigFile).buckets;
const data = concertsData as ConcertsDataFile;
const knownVenues = collectKnownVenues(buckets);
const birthdays = (birthdaysData as BirthdaysDataFile).entries ?? [];

const today = new Date().toISOString().slice(0, 10);
const upcoming: ConcertEntry[] = (data.entries ?? [])
  .filter((e) => {
    const compareDate = e.endDate ?? e.date;
    return compareDate >= today;
  })
  .map((e) => reparseEntry(e, knownVenues))
  .map((e) => ({ ...e, buckets: categorize(e, buckets) }));

const grouped = groupByBucket(upcoming, buckets);

// Coming Up Next — the next 8 entries across the WHOLE calendar, regardless
// of bucket. Sorted by date ascending.
const comingUp = [...upcoming]
  .sort((a, b) => a.date.localeCompare(b.date))
  .slice(0, 8);

// Bucket teasers — one tile per bucket, with the count and short description.
// Plus a Venues tile (same visual pattern, lives at /venues).
const BUCKET_HREFS: Record<string, string> = {
  'florida-metal-scene': '/florida',
  'japanese-metal': '/japan',
  'key-festivals': '/festivals',
  'interesting-elsewhere': '/elsewhere',
  'album-releases': '/releases',
};

const bucketTeasers = buckets.map((b) => ({
  id: b.id,
  name: b.name,
  kanji: b.kanji,
  description: b.description,
  count: grouped.get(b.id)?.length ?? 0,
  href: BUCKET_HREFS[b.id] ?? '/',
}));

const birthdaysTeaser = {
  id: 'birthdays',
  name: 'Birthdays',
  kanji: undefined as string | undefined,
  description: 'Artists, players, and the people behind the bands we follow. Sorted by next-up.',
  count: birthdays.length,
  href: '/birthdays',
};

const venuesTeaser = {
  id: 'venues',
  name: 'Go-To Venues',
  kanji: undefined as string | undefined,
  description: "The rooms Kevin anchors his coverage on. One per city — where the bands you care about actually play.",
  count: null as number | null,
  href: '/venues',
};

const teasers = [...bucketTeasers, birthdaysTeaser, venuesTeaser];

const lastUpdated = data.generatedAt
  ? new Date(data.generatedAt).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    })
  : null;
---

<BaseLayout
  title="The Music Cities — Concerts Dashboard"
  description="Curated metal concerts, festivals, and album releases across Florida, Japan, and the wider scene. Updated nightly."
>
  <Header />
  <SceneNav buckets={buckets} grouped={grouped} birthdaysCount={birthdays.length} />

  <section class="hero-strip">
    <div class="container">
      <h1 class="hero-strip__lede">
        Concerts. Releases. <em>The scene.</em>
      </h1>
      <p class="hero-strip__body">
        Not an aggregator. This is the calendar Kevin actually pays attention to —
        Florida's metal venues, the Japanese watch list, marquee festivals, new
        releases, livestreams, and the records on heavy rotation.
        {lastUpdated ? <span>Last updated {lastUpdated}.</span> : null}
      </p>
    </div>
  </section>

  <section class="field-trip-strip">
    <div class="container">
      <a href="/london/" class="field-trip-strip__link">
        <span class="field-trip-strip__eyebrow">Field Trip</span>
        <h2 class="field-trip-strip__title">Metal <em>London</em> — A NWOBHM Pilgrimage</h2>
        <p class="field-trip-strip__sub">Sunday 2 — Tuesday 4 August 2026 · Lovebites @ O2 Academy Islington + the city's metal stops</p>
        <span class="field-trip-strip__cta">View the trip plan →</span>
      </a>
    </div>
  </section>

  <section class="coming-up">
    <div class="container">
      <header class="coming-up__header">
        <span class="coming-up__eyebrow">Coming up next</span>
        <h2 class="coming-up__title">The next eight on the calendar</h2>
        <p class="coming-up__sub">Across every bucket, soonest first. Use the bucket pages for the full lists.</p>
      </header>
      {comingUp.length === 0 ? (
        <p class="bucket__empty">Nothing on the calendar yet. Check back soon.</p>
      ) : (
        <div class="bucket__grid">
          {comingUp.map((entry) =>
            entry.isRelease ? <ReleaseCard entry={entry} /> : <ShowCard entry={entry} />,
          )}
        </div>
      )}
    </div>
  </section>

  <section class="scenes">
    <div class="container">
      <header class="scenes__header">
        <span class="scenes__eyebrow">The scenes</span>
        <h2 class="scenes__title">Pick your beat</h2>
        <p class="scenes__sub">Each tile is its own page — bucket, count, and the editorial scope behind it.</p>
      </header>

      <div class="bucket-teasers">
        {teasers.map((t) => (
          <a href={t.href} class="bucket-teaser">
            <h3 class="bucket-teaser__name">
              {t.name}
              {t.kanji ? <span class="bucket-teaser__kanji" lang="ja">{t.kanji}</span> : null}
            </h3>
            {t.count !== null ? <p class="bucket-teaser__count">{t.count} {t.count === 1 ? 'entry' : 'entries'}</p> : null}
            <p class="bucket-teaser__desc">{t.description}</p>
            <span class="bucket-teaser__cta">View all →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
